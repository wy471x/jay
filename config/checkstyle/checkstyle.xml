<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Puppy Crawl//DTD Check Configuration 1.3//EN"
    "http://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">

    <property name="localeLanguage" value="en"/>

    <!-- Prohibit tab characters in source files -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- Prohibit System.out.println in production code -->
    <module name="RegexpSingleline">
        <property name="format" value="System\.out\.println"/>
        <property name="message" value="Prohibit invoking System.out.println in source code !"/>
    </module>

    <!-- Prohibit Chinese characters in source code -->
    <module name="RegexpSingleline">
        <property name="format"
                  value=".*[\u3400-\u4DB5\u4E00-\u9FA5\u9FA6-\u9FBB\uF900-\uFA2D\uFA30-\uFA6A\uFA70-\uFAD9\uFF00-\uFFEF\u2E80-\u2EFF\u3000-\u303F\u31C0-\u31EF]+.*"/>
        <property name="message" value="Not allow chinese character !"/>
    </module>

    <!-- Maximum file length: 3000 lines -->
    <module name="FileLength">
        <property name="max" value="3000"/>
    </module>

    <module name="TreeWalker">

        <!-- Import rules -->
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="AvoidStarImport"/>

        <module name="NonEmptyAtclauseDescription"/>

        <!-- Checks that classes that override equals() also override hashCode() -->
        <module name="EqualsHashCode"/>

        <!-- Checks for over-complicated boolean expressions -->
        <module name="SimplifyBooleanExpression"/>

        <module name="OneStatementPerLine"/>

        <module name="UnnecessaryParentheses"/>

        <!-- Checks for over-complicated boolean return statements -->
        <module name="SimplifyBooleanReturn"/>

        <!-- Check that default is after all cases in switch statement -->
        <module name="DefaultComesLast"/>

        <!-- Detects empty statements (standalone ";" semicolon) -->
        <module name="EmptyStatement"/>

        <!-- Checks that long constants are defined with an upper ell -->
        <module name="UpperEll"/>

        <!-- Naming conventions - Constants -->
        <module name="ConstantName">
            <property name="format" value="(^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$)"/>
        </module>

        <!-- Validates identifiers for local, non-final variables -->
        <module name="LocalVariableName"/>

        <!-- Validates identifiers for local, final variables, including catch parameters -->
        <module name="LocalFinalVariableName"/>

        <!-- Validates identifiers for non-static fields -->
        <module name="MemberName"/>

        <!-- Validates identifiers for class type parameters -->
        <module name="ClassTypeParameterName">
            <property name="format" value="(^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$)"/>
        </module>

        <!-- Validates identifiers for method type parameters -->
        <module name="MethodTypeParameterName">
            <property name="format" value="(^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$)"/>
        </module>

        <!-- Package naming convention: com.jay.[module].[submodule] -->
        <module name="PackageName">
            <property name="format" value="^(com)\.jay(\.[a-z][a-z0-9]*)+$"/>
        </module>

        <!-- Validates identifiers for method parameters -->
        <module name="ParameterName"/>

        <!-- Static variable naming convention -->
        <module name="StaticVariableName">
            <property name="format" value="(^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$)"/>
        </module>

        <!-- Type naming convention -->
        <module name="TypeName">
            <property name="format" value="(^[A-Z][a-zA-Z0-9]*$)|(^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$)"/>
        </module>

        <!-- Require @Override annotation when overriding -->
        <module name="MissingOverride"/>

        <!-- Whitespace rules -->
        <module name="GenericWhitespace"/>
        <module name="WhitespaceAfter"/>
        <module name="WhitespaceAround"/>
        <module name="MethodParamPad"/>
        <module name="ParenPad"/>
        <module name="TypecastParenPad"/>

        <!-- Empty line separator rules -->
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="allowMultipleEmptyLines" value="false"/>
            <property name="allowMultipleEmptyLinesInsideClassMembers" value="false"/>
        </module>

    </module>

    <!-- Exclude test and generated sources from some checks -->
    <module name="SuppressionSingleFilter">
        <property name="files" value=".*[\\/]generated[\\/].*"/>
    </module>

</module>
